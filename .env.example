# ── WhatsApp Cloud API ─────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_access_token_from_meta
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_from_meta
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose_for_webhook_verification
WHATSAPP_APP_SECRET=your_meta_app_secret_for_signature_verification

# Authorized doctor WhatsApp number(s), E.164 digits, no + sign.
# Comma-separated for multiple doctors — each gets an isolated conversation
# session automatically; they share the clinic's patient pool. All other
# senders are silently rejected (and logged server-side).
DOCTOR_WHATSAPP_NUMBER=628119856889,628123456789

# Knowledge-mode number(s), same format. Messages from these numbers become
# knowledge-bank notes (Dr. Denish's second brain), NOT patient records.
KNOWLEDGE_MODE_NUMBERS=14016882393

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-5
MAX_TOKENS_PER_REQUEST=1024
# Adaptive thinking is OFF by default to keep token spend minimal for this
# structured tool-dispatch bot. Set true only if reasoning quality on tricky
# messages matters more than cost.
ENABLE_THINKING=false
# Cheaper model for knowledge-bank note tidying (topic/summary) — a light task.
KNOWLEDGE_MODEL=claude-haiku-4-5

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# ── Groq (voice-note transcription — Whisper) ──────────────────────────────────
GROQ_API_KEY=gsk_your-groq-key-here

# ── App ───────────────────────────────────────────────────────────────────────
CLINIC_NAME=DG Clinic
DOCTOR_NAME=Dr. Denish
DEBUG=false
