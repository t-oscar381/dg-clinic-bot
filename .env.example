# ── WhatsApp Cloud API ─────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_access_token_from_meta
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_from_meta
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose_for_webhook_verification
WHATSAPP_APP_SECRET=your_meta_app_secret_for_signature_verification

# Doctor's WhatsApp number (E.164 format, no + sign)
# Only this number can use the bot — all others are rejected
DOCTOR_WHATSAPP_NUMBER=628123456789

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-5
MAX_TOKENS_PER_REQUEST=1024
# Adaptive thinking is OFF by default to keep token spend minimal for this
# structured tool-dispatch bot. Set true only if reasoning quality on tricky
# messages matters more than cost.
ENABLE_THINKING=false

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# ── Groq (voice-note transcription — Whisper) ──────────────────────────────────
GROQ_API_KEY=gsk_your-groq-key-here

# ── App ───────────────────────────────────────────────────────────────────────
CLINIC_NAME=DG Clinic
DOCTOR_NAME=Dr. Denish
DEBUG=false
